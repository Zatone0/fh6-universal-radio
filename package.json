{
  "name": "fh6-universal-radio-tooling",
  "private": true,
  "version": "0.0.0",
  "description": "Lint/format/test tooling for the FH6 Universal Radio dashboard (ui/dist).",
  "scripts": {
    "format":       "prettier --write \"ui/**/*.{js,css,html}\"",
    "format:check": "prettier --check \"ui/**/*.{js,css,html}\"",
    "lint:js":      "eslint \"ui/**/*.js\"",
    "lint:css":     "stylelint \"ui/**/*.css\"",
    "lint":         "npm run lint:js && npm run lint:css",
    "test":         "vitest run",
    "test:watch":   "vitest",
    "check":        "npm run format:check && npm run lint && npm run test",
    "fix":          "npm run format && eslint --fix \"ui/**/*.js\" && stylelint --fix \"ui/**/*.css\""
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "eslint": "^9.15.0",
    "globals": "^15.12.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.3.3",
    "stylelint": "^16.10.0",
    "stylelint-config-standard": "^36.0.1",
    "vitest": "^2.1.8"
  }
}
